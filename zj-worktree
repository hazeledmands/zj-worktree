#!/usr/bin/env bash
set -euo pipefail

# Ignore SIGPIPE: when an agent harness captures our output through a pipe and
# closes it mid-stream, we don't want the signal to kill us before the work
# (worktree create, tab open, archive flip) completes. With this trap, writes
# to a closed pipe return EPIPE instead; helpers below mask that under set -e.
trap '' PIPE

# Resolve the script's real directory so lib/ helpers work through symlinks.
self="${BASH_SOURCE[0]}"
while [[ -L "$self" ]]; do
    link_target="$(readlink "$self")"
    if [[ "$link_target" = /* ]]; then
        self="$link_target"
    else
        self="$(dirname "$self")/$link_target"
    fi
done
ROOT="$(cd "$(dirname "$self")" && pwd -P)"
LIB="$ROOT/lib"

# -----------------------------------------------------------------------------
# Output helpers
#
# `progress` writes informational "◎ ..." lines to stderr — but only when
# stderr is a TTY. In a pipe (agent harness), they'd be noise and would race
# with the consumer closing the pipe, so we drop them entirely.
#
# `say` writes a finish line (e.g. "Opened tab '...'") to stdout, tolerating
# a broken pipe so a consumer that closed early can't kill us after the work
# already completed.
#
# `result` emits a stable, machine-parseable last-line contract. Agents can
# grep `^result: ` to confirm the operation finished without parsing prose.
# -----------------------------------------------------------------------------

progress() {
    [[ -t 2 ]] || return 0
    printf '%s\n' "$*" >&2
}

say() {
    printf '%s\n' "$*" || :
}

result() {
    # Args are pre-formatted "key=value" pairs after the action name.
    # Example: result created tab=foo worktree=/path
    printf 'result: %s\n' "$*" || :
}

usage() {
    cat <<'USAGE'
Usage:
  zj-worktree --branch <branch> --tab <name> [--repo <path>] [--base <ref>] [--prompt <text>]
  zj-worktree --branch <branch> --tab <name> --resume
  zj-worktree --pr <number> --tab <name> [--repo <path>] [--prompt <text>]
  zj-worktree --dir <path> --tab <name> [--prompt <text>]

Subcommands:
  zj-worktree archive [--remove]                   Close current tab; write archive entry
                                                   (reads summary body from stdin).
  zj-worktree resume <keyword> [--no-dispatch]     Restore an archived tab matching <keyword>.
  zj-worktree list [--status S] [--limit N] [--format tsv|human]
                                                   Show active + archived tabs.

Create options:
  --branch <branch>  Create a new worktree for this branch (via wt switch --create)
  --pr <number>      Check out a PR's branch with remote tracking (via wt switch pr:<N>)
  --dir <path>       Use an existing worktree directory
  --repo <path>      Target repo for --branch / --pr (default: current cwd's repo).
                     Use this when dispatching into a different repo than the caller's cwd.
                     Mutually exclusive with --dir.
  --base <ref>       Base ref for new branch (default: origin/<default-branch>).
                     Use this for stacked/nested PRs. Only valid with --branch.
  --tab <name>       Name for the new zellij tab (required)
  --prompt <text>    Initial prompt to send to Claude
  --resume           Resume the most recent Claude conversation in the worktree
  -h, --help         Show this help
USAGE
}

# -----------------------------------------------------------------------------
# Shared archive helpers
# -----------------------------------------------------------------------------

archive_dir_path() { echo "${ARCHIVE_DIR:-$HOME/.claude/archive}"; }

git_main_repo() {
    # Print the absolute path of the main checkout for the current cwd. The
    # obvious form `git worktree list --porcelain | awk '/^worktree /{print $2;
    # exit}'` is fragile: awk's early exit closes the pipe, git gets SIGPIPE on
    # its next write, and dies with 141. Our `trap '' PIPE` only protects this
    # shell — child processes inherit SIG_DFL — so under set -e -o pipefail the
    # whole script dies before producing any user-facing output. Capture the
    # porcelain list first, then parse it without a pipeline producer.
    local wt_list
    wt_list=$(git worktree list --porcelain)
    awk '/^worktree /{print $2; exit}' <<<"$wt_list"
}

entry_path_for() {
    # entry_path_for <repo> <branch>  →  prints absolute path of the per-tab .md.
    local repo="$1" branch="$2" slug
    slug="${branch//\//-}"
    echo "$(archive_dir_path)/${repo}-${slug}.md"
}

write_active_entry() {
    # write_active_entry <repo> <branch> <worktree> <tab>
    # Writes a per-tab .md with status=active. Preserves dispatched: from any
    # existing entry, so a resume → re-dispatch keeps the original date.
    local repo="$1" branch="$2" worktree="$3" tab="$4"
    local today entry dispatched
    today="$(date +%Y-%m-%d)"
    entry="$(entry_path_for "$repo" "$branch")"
    dispatched="$today"
    if [[ -f "$entry" ]]; then
        local prev
        prev="$(sed -n 's/^dispatched: //p' "$entry")"
        prev="${prev%%$'\n'*}"
        [[ -n "$prev" ]] && dispatched="$prev"
    fi
    mkdir -p "$(archive_dir_path)"
    local body=""
    if [[ -f "$entry" ]]; then
        # Preserve existing body across a resume.
        body="$(awk 'BEGIN{s=0} /^---$/{s++;next} s==2{print}' "$entry")"
    fi
    [[ -z "$body" ]] && body="Just dispatched. No notes yet."
    cat > "$entry" <<EOF
---
tab: $tab
branch: $branch
worktree: $worktree
repo: $repo
status: active
dispatched: $dispatched
last_updated: $today
---

$body
EOF
    echo "$entry"
}

# -----------------------------------------------------------------------------
# cmd_create — original "open a tab in a worktree" flow
# -----------------------------------------------------------------------------

cmd_create() {
    local branch="" pr="" dir="" repo="" base="" tab_name="" prompt=""
    local resume=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --branch) branch="$2"; shift 2 ;;
            --pr)     pr="$2"; shift 2 ;;
            --dir)    dir="$2"; shift 2 ;;
            --repo)   repo="$2"; shift 2 ;;
            --base)   base="$2"; shift 2 ;;
            --tab)    tab_name="$2"; shift 2 ;;
            --prompt) prompt="$2"; shift 2 ;;
            --resume) resume=true; shift ;;
            -h|--help) usage; exit 0 ;;
            *) echo "Error: unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
    done

    # --- Validation ---

    # $ZELLIJ is only set inside a zellij pane. Detached contexts (e.g. an
    # agent background job) don't inherit it, but can still drive a running
    # session: `zellij action` targets whatever $ZELLIJ_SESSION_NAME names.
    # So don't hard-fail on an empty $ZELLIJ — resolve a live session instead.
    if [[ -z "${ZELLIJ:-}" ]]; then
        local live_sessions
        live_sessions=$(zellij list-sessions 2>/dev/null \
            | sed -E 's/\x1b\[[0-9;]*m//g' \
            | grep -v 'EXITED' \
            | awk '{print $1}')
        if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]] && grep -qxF "$ZELLIJ_SESSION_NAME" <<<"$live_sessions"; then
            : # $ZELLIJ_SESSION_NAME already points at a live session
        elif [[ "$(grep -c . <<<"$live_sessions")" -eq 1 ]]; then
            export ZELLIJ_SESSION_NAME="$live_sessions"
        else
            echo "Error: not inside a zellij session, and could not resolve a single live one to target." >&2
            echo "       Set ZELLIJ_SESSION_NAME to a running session and retry." >&2
            exit 1
        fi
    fi

    if [[ -z "$tab_name" ]]; then
        echo "Error: --tab is required" >&2
        exit 1
    fi

    if [[ -z "$branch" && -z "$pr" && -z "$dir" ]]; then
        echo "Error: one of --branch, --pr, or --dir is required" >&2
        exit 1
    fi

    if [[ -n "$base" && -z "$branch" ]]; then
        echo "Error: --base is only valid with --branch" >&2
        exit 1
    fi

    if [[ -n "$repo" && -n "$dir" ]]; then
        echo "Error: --repo and --dir are mutually exclusive" >&2
        exit 1
    fi

    # Run git/wt operations against --repo instead of the caller's cwd when set.
    # Useful for dispatching into a repo different from the one the caller is in.
    if [[ -n "$repo" ]]; then
        if [[ ! -d "$repo" ]]; then
            echo "Error: --repo path does not exist: $repo" >&2
            exit 1
        fi
        if ! git -C "$repo" rev-parse --git-dir &>/dev/null; then
            echo "Error: --repo is not a git repository: $repo" >&2
            exit 1
        fi
        cd "$repo"
    fi

    # --- Resolve worktree path ---

    local worktree_path=""
    local main_repo=""

    if [[ -n "$pr" ]]; then
        if ! git rev-parse --git-dir &>/dev/null; then
            echo "Error: not inside a git repository" >&2
            exit 1
        fi
        main_repo=$(git_main_repo)
        # Capture so wt's output doesn't share our (possibly-closed) stdout.
        # Rust binaries panic on EPIPE writes even with our PIPE trap.
        local wt_out wt_rc=0
        wt_out=$(wt -C "$main_repo" switch "pr:${pr}" --no-cd --yes 2>&1) || wt_rc=$?
        if (( wt_rc != 0 )); then
            echo "Error: wt switch pr:${pr} failed (exit $wt_rc):" >&2 || :
            [[ -n "$wt_out" ]] && echo "$wt_out" >&2 || :
            exit "$wt_rc"
        fi
        branch=$(gh pr view "$pr" --json headRefName --jq '.headRefName')
        worktree_path=$(wt list --format=json | jq -r --arg b "$branch" \
            '.[] | select(.branch == $b) | .path')
        if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
            echo "Error: could not find worktree path for PR #${pr} (branch '$branch')" >&2
            echo "Check 'wt list' to see available worktrees." >&2
            exit 1
        fi
    elif [[ -n "$branch" ]]; then
        if ! git rev-parse --git-dir &>/dev/null; then
            echo "Error: not inside a git repository" >&2
            exit 1
        fi
        main_repo=$(git_main_repo)

        local base_flag=()
        if [[ -n "$base" ]]; then
            base_flag=(--base "$base")
        else
            local default_branch
            default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
            default_branch="${default_branch:-main}"
            progress "◎ Fetching ${default_branch} from origin..."
            # Capture so any --quiet-bypassed writes don't share our stdout.
            local fetch_out
            if fetch_out=$(git fetch origin "$default_branch" --quiet 2>&1); then
                base_flag=(--base "origin/${default_branch}")
            else
                echo "⚠ Could not fetch from origin; branching from local ${default_branch}" >&2 || :
                [[ -n "$fetch_out" ]] && echo "$fetch_out" >&2 || :
            fi
        fi

        local create_output
        create_output=$(wt -C "$main_repo" switch --create "$branch" "${base_flag[@]}" --no-cd --yes 2>&1) || {
            if ! grep -qi "already exists" <<<"$create_output"; then
                echo "$create_output" >&2
            fi
            worktree_path=$(wt list --format=json | jq -r --arg b "$branch" \
                '.[] | select(.branch == $b) | .path')
            if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
                progress "◎ Creating worktree for existing branch '$branch'..."
                local wt2_out wt2_rc=0
                wt2_out=$(wt -C "$main_repo" switch "$branch" --no-cd --yes 2>&1) || wt2_rc=$?
                if (( wt2_rc != 0 )); then
                    echo "Error: wt switch '$branch' failed (exit $wt2_rc):" >&2 || :
                    [[ -n "$wt2_out" ]] && echo "$wt2_out" >&2 || :
                    exit "$wt2_rc"
                fi
            else
                progress "◎ Using existing worktree for '$branch'"
            fi
        }

        if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
            worktree_path=$(wt list --format=json | jq -r --arg b "$branch" \
                '.[] | select(.branch == $b) | .path')
        fi
        if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
            echo "Error: could not find worktree path for branch '$branch'" >&2
            echo "Check 'wt list' to see available worktrees." >&2
            exit 1
        fi
    else
        worktree_path="$dir"
        if [[ ! -d "$worktree_path" ]]; then
            echo "Error: directory does not exist: $worktree_path" >&2
            exit 1
        fi
    fi

    # --- Write/refresh per-tab archive entry (when we have a branch + main_repo) ---
    # --dir-only dispatches don't have a branch/repo identity, so skip.

    local entry_path=""
    if [[ -n "$branch" && -n "$main_repo" ]]; then
        local repo_name
        repo_name="$(basename "$main_repo")"
        entry_path="$(write_active_entry "$repo_name" "$branch" "$worktree_path" "$tab_name")"
    fi

    # --- Augment prompt with checkpoint-on-idle primer ---
    # Only applies when --prompt is set. --resume reuses the prior conversation
    # (which already contains the primer from the original dispatch).
    if [[ -n "$prompt" && -n "$entry_path" ]]; then
        prompt="$prompt

(Your archive entry: $entry_path. Before going idle on this tab, if you've made meaningful progress since your last checkpoint, update its body with a 1–3 sentence summary and bump 'last_updated:' to today.)"
    fi

    # --- Build layout ---

    local base_layout="$HOME/.config/zellij/layouts/claude-tab.kdl"
    local tmpdir
    tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/zj-worktree-XXXXXX")

    for f in .zshenv .zprofile .zlogin .zlogout; do
        [[ -f "$HOME/$f" ]] && ln -s "$HOME/$f" "$tmpdir/$f"
    done

    local claude_cmd
    if [[ "$resume" == true ]]; then
        claude_cmd=$(printf '%q ' claude --resume)
    elif [[ -n "$prompt" ]]; then
        claude_cmd=$(printf '%q ' claude "$prompt")
    else
        claude_cmd="claude"
    fi

    cat > "$tmpdir/.zshrc" <<ZSHRC
source ~/.zshrc
eval "\$(direnv export zsh)"
$claude_cmd
zshexit() { rm -rf "$tmpdir"; }
ZSHRC

    local status_bar_pane
    status_bar_pane=$(awk '/^layout \{/{next} /pane command=/{exit} {print}' "$base_layout")

    local layout_file="$tmpdir/layout.kdl"
    cat > "$layout_file" <<LAYOUT
layout {
$status_bar_pane
    pane command="zsh" size="80%" {
        args "-c" "export ZDOTDIR='$tmpdir'; exec zsh -li"
    }
    pane command="zsh" size="20%" {
        args "-lic" "eval \"\$(direnv export zsh)\"; exec $HOME/.local/bin/prwatch"
    }
}
LAYOUT

    # --- Open the tab ---
    #
    # Capture zellij's output so it doesn't share our stdout. zellij is a
    # Rust binary and panics on EPIPE writes (even though our shell ignores
    # SIGPIPE), so when an agent harness closes our stdout pipe, a single
    # status byte from zellij can kill the action mid-dispatch. By keeping
    # zellij's stdout pointed at our capture pipe, the new-tab IPC request
    # always completes regardless of what the agent harness does with ours.
    local zellij_out zellij_rc=0
    zellij_out=$(zellij action new-tab --name "$tab_name" --cwd "$worktree_path" --layout "$layout_file" 2>&1) || zellij_rc=$?
    if (( zellij_rc != 0 )); then
        echo "Error: zellij action new-tab failed (exit $zellij_rc):" >&2 || :
        [[ -n "$zellij_out" ]] && echo "$zellij_out" >&2 || :
        exit "$zellij_rc"
    fi

    say "Opened tab '$tab_name' in $worktree_path"

    # Machine-readable result contract. Always last line on stdout for
    # successful create; agents can grep `^result: created`.
    local result_fields="created tab=$tab_name worktree=$worktree_path"
    [[ -n "$branch" ]] && result_fields="$result_fields branch=$branch"
    [[ -n "$entry_path" ]] && result_fields="$result_fields entry=$entry_path"
    result "$result_fields"
}

# -----------------------------------------------------------------------------
# cmd_archive — close current tab, write archive entry
# -----------------------------------------------------------------------------

cmd_archive() {
    local remove=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --remove) remove=1; shift ;;
            -h|--help) echo "usage: zj-worktree archive [--remove]  (reads body from stdin)"; exit 0 ;;
            *) echo "Error: unknown option for 'archive': $1" >&2; exit 1 ;;
        esac
    done

    if ! git rev-parse --git-dir &>/dev/null; then
        echo "Error: not inside a git repository" >&2
        exit 1
    fi

    local worktree main
    worktree="$(git rev-parse --show-toplevel)"
    main="$(git_main_repo)"
    if [[ "$worktree" == "$main" ]]; then
        echo "Error: 'archive' is meant to be run from a secondary worktree, not the main checkout." >&2
        exit 1
    fi

    local branch repo today
    branch="$(git branch --show-current)"
    if [[ -z "$branch" ]]; then
        echo "Error: detached HEAD; cannot determine branch for archive entry" >&2
        exit 1
    fi
    repo="$(basename "$main")"
    today="$(date +%Y-%m-%d)"

    # Read the summary body from stdin.
    local body
    body="$(cat)"
    if [[ -z "$body" ]]; then
        echo "Error: archive needs a summary body on stdin (1–3 sentences)" >&2
        exit 1
    fi

    # Resolve tab name + pane sketch via find-tab.sh. Fall back to branch name.
    local tab_name="" pane_sketch=""
    local find_out=""
    if find_out="$("$LIB/find-tab.sh" "$worktree" 2>/dev/null)"; then
        local first
        first="$(head -1 <<<"$find_out")"
        tab_name="$(cut -f3 <<<"$first")"
        pane_sketch="$(tail -n +2 <<<"$find_out")"
    fi
    [[ -z "$tab_name" ]] && tab_name="$(basename "$branch")"

    local full_body="$body"
    if [[ -n "$pane_sketch" ]]; then
        full_body+=$'\n\n**Tab state at archive:**\n'"$pane_sketch"
    fi

    # Preserve dispatched: from any prior entry.
    local entry dispatched
    entry="$(entry_path_for "$repo" "$branch")"
    dispatched="$today"
    if [[ -f "$entry" ]]; then
        local prev
        prev="$(sed -n 's/^dispatched: //p' "$entry")"
        prev="${prev%%$'\n'*}"
        [[ -n "$prev" ]] && dispatched="$prev"
    fi
    mkdir -p "$(archive_dir_path)"

    cat > "$entry" <<EOF
---
tab: $tab_name
branch: $branch
worktree: $worktree
repo: $repo
status: archived
dispatched: $dispatched
last_updated: $today
archived: $today
---

$full_body
EOF

    # Close the tab (with optional --remove of the worktree).
    local close_args=()
    (( remove )) && close_args+=(--remove)
    close_args+=("$worktree")

    local close_rc=0
    "$LIB/close-tab.sh" "${close_args[@]}" || close_rc=$?

    case "$close_rc" in
        0) say "Archived '$tab_name' ($branch). Entry: $entry" ;;
        1) say "Archive entry written; no tab hosted this worktree, so nothing to close. Entry: $entry" ;;
        2) echo "Archive entry written; multiple tabs host this worktree — close manually. Entry: $entry" >&2 || :; exit 2 ;;
        3) echo "Archive entry written; zellij/jq unavailable, tab not closed. Entry: $entry" >&2 || : ;;
        4) echo "Archive entry written; close-tab-by-id failed. Entry: $entry" >&2 || :; exit 4 ;;
        5) echo "Archive entry written; 'wt remove' failed and tab not closed. Entry: $entry" >&2 || :; exit 5 ;;
        *) echo "Archive entry written; close-tab.sh exited $close_rc. Entry: $entry" >&2 || :; exit "$close_rc" ;;
    esac

    result "archived tab=$tab_name branch=$branch entry=$entry"
}

# -----------------------------------------------------------------------------
# cmd_resume — find archived entry by keyword, restore the tab
# -----------------------------------------------------------------------------

flip_to_active() {
    # flip_to_active <file>
    # Flips status to active, bumps last_updated to today, drops `archived:`.
    local file="$1"
    local today tmp
    today="$(date +%Y-%m-%d)"
    tmp="$(mktemp)"
    awk -v today="$today" '
        BEGIN { state = 0 }
        state == 0 && /^---$/ { state = 1; print; next }
        state == 1 && /^---$/ { state = 2; print; next }
        state == 1 && /^status:/       { print "status: active"; next }
        state == 1 && /^last_updated:/ { print "last_updated: " today; next }
        state == 1 && /^archived:/     { next }
        { print }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

cmd_resume() {
    local keyword="" no_dispatch=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-dispatch) no_dispatch=1; shift ;;
            -h|--help) echo "usage: zj-worktree resume <keyword> [--no-dispatch]"; exit 0 ;;
            --*) echo "Error: unknown option for 'resume': $1" >&2; exit 1 ;;
            *)
                if [[ -z "$keyword" ]]; then
                    keyword="$1"; shift
                else
                    echo "Error: too many positional arguments to 'resume'" >&2; exit 1
                fi
                ;;
        esac
    done

    if [[ -z "$keyword" ]]; then
        echo "Error: 'resume' requires a keyword. usage: zj-worktree resume <keyword>" >&2
        exit 1
    fi

    local all
    all="$("$LIB/list-tabs.sh")" || true

    if [[ -z "$all" ]]; then
        echo "no matching archive entry for '$keyword' (archive is empty)" >&2
        exit 1
    fi

    local matches
    matches="$(echo "$all" | grep -F -- "$keyword" || true)"
    if [[ -z "$matches" ]]; then
        echo "no matching archive entry for '$keyword'" >&2
        exit 1
    fi

    local match_count
    match_count="$(echo "$matches" | wc -l | tr -d ' ')"
    if (( match_count > 1 )); then
        echo "multiple archive entries match '$keyword':" >&2
        echo "$matches" >&2
        exit 2
    fi

    # Parse fields via awk — see cmd_list for the IFS-whitespace gotcha.
    local status last_updated repo branch tab worktree hook
    status="$(echo "$matches" | awk -F'\t' '{print $1}')"
    last_updated="$(echo "$matches" | awk -F'\t' '{print $2}')"
    repo="$(echo "$matches" | awk -F'\t' '{print $3}')"
    branch="$(echo "$matches" | awk -F'\t' '{print $4}')"
    tab="$(echo "$matches" | awk -F'\t' '{print $5}')"
    worktree="$(echo "$matches" | awk -F'\t' '{print $6}')"
    hook="$(echo "$matches" | awk -F'\t' '{print $7}')"

    # Derive the main checkout path from the worktree path + repo name.
    # Convention: <main-parent>/<repo-name>.<branch-slug>  →  <main-parent>/<repo-name>
    local main
    main="$(dirname "$worktree")/$repo"

    if (( no_dispatch )); then
        echo "would resume: repo=$main branch=$branch tab=$tab worktree=$worktree"
        return 0
    fi

    if [[ ! -d "$main" ]]; then
        echo "Error: main checkout not found at $main (derived from worktree=$worktree, repo=$repo)" >&2
        exit 1
    fi

    # Flip the entry back to active before dispatching.
    local entry
    entry="$(entry_path_for "$repo" "$branch")"
    [[ -f "$entry" ]] && flip_to_active "$entry"

    # Hand off to cmd_create via the existing flag interface.
    cmd_create --repo "$main" --branch "$branch" --tab "$tab" --resume
}

# -----------------------------------------------------------------------------
# cmd_list — pretty-print the result of lib/list-tabs.sh
# -----------------------------------------------------------------------------

cmd_list() {
    local status_filter="" limit="" format="human"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status) status_filter="$2"; shift 2 ;;
            --limit)  limit="$2"; shift 2 ;;
            --format) format="$2"; shift 2 ;;
            -h|--help) echo "usage: zj-worktree list [--status active|archived] [--limit N] [--format tsv|human]"; exit 0 ;;
            *) echo "Error: unknown option for 'list': $1" >&2; exit 1 ;;
        esac
    done

    local args=()
    [[ -n "$status_filter" ]] && args+=(--status "$status_filter")
    [[ -n "$limit" ]] && args+=(--limit "$limit")

    local tsv
    tsv="$("$LIB/list-tabs.sh" "${args[@]}")"
    if [[ -z "$tsv" ]]; then
        return 0
    fi

    if [[ "$format" == "tsv" ]]; then
        echo "$tsv" || :
        return 0
    fi

    # Use awk for TSV parsing: bash's `read -d $'\t'` coalesces empty leading
    # fields because tab counts as whitespace in IFS, which mangles legacy
    # entries whose status field is blank.
    #
    # `2>/dev/null || true`: when a consumer pipes our output into `head -n`
    # or similar and closes the read side mid-stream, awk's next write fails
    # with EPIPE; suppress its "write error" complaint and don't let the
    # non-zero exit propagate through set -o pipefail + set -e.
    awk -F'\t' '
        NF >= 7 {
            printf "%s [%s] %s (%s, %s) — %s\n", $2, $1, $5, $3, $4, $7
        }
    ' <<<"$tsv" 2>/dev/null || true
}

# -----------------------------------------------------------------------------
# Dispatch
# -----------------------------------------------------------------------------

if [[ $# -eq 0 ]]; then
    usage; exit 0
fi

# Subcommand if the first arg is a bare word (doesn't start with -).
case "$1" in
    -h|--help) usage; exit 0 ;;
    -*)        cmd_create "$@" ;;
    archive)   shift; cmd_archive "$@" ;;
    resume)    shift; cmd_resume "$@" ;;
    list)      shift; cmd_list "$@" ;;
    create)    shift; cmd_create "$@" ;;
    *)         echo "Error: unknown subcommand: $1" >&2; usage >&2; exit 1 ;;
esac
