#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage:
  zj-worktree --branch <branch> --tab <name> [--prompt <text>]
  zj-worktree --branch <branch> --tab <name> --resume
  zj-worktree --pr <number> --tab <name> [--prompt <text>]
  zj-worktree --dir <path> --tab <name> [--prompt <text>]

Create a new zellij tab with Claude running in a git worktree.

Options:
  --branch <branch>  Create a new worktree for this branch (via wt switch --create)
  --pr <number>      Check out a PR's branch with remote tracking (via wt switch pr:<N>)
  --dir <path>       Use an existing worktree directory
  --tab <name>       Name for the new zellij tab (required)
  --prompt <text>    Initial prompt to send to Claude
  --resume           Resume the most recent Claude conversation in the worktree
  -h, --help         Show this help
USAGE
}

branch=""
pr=""
dir=""
tab_name=""
prompt=""
resume=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --branch) branch="$2"; shift 2 ;;
        --pr)     pr="$2"; shift 2 ;;
        --dir)    dir="$2"; shift 2 ;;
        --tab)    tab_name="$2"; shift 2 ;;
        --prompt) prompt="$2"; shift 2 ;;
        --resume) resume=true; shift ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Error: unknown option: $1" >&2; usage >&2; exit 1 ;;
    esac
done

# --- Validation ---

if [[ -z "${ZELLIJ:-}" ]]; then
    echo "Error: not inside a zellij session" >&2
    exit 1
fi

if [[ -z "$tab_name" ]]; then
    echo "Error: --tab is required" >&2
    exit 1
fi

if [[ -z "$branch" && -z "$pr" && -z "$dir" ]]; then
    echo "Error: one of --branch, --pr, or --dir is required" >&2
    exit 1
fi

# --- Resolve worktree path ---

worktree_path=""

if [[ -n "$pr" ]]; then
    # Check out a PR branch with remote tracking via wt switch pr:<N>.
    if ! git rev-parse --git-dir &>/dev/null; then
        echo "Error: not inside a git repository" >&2
        exit 1
    fi

    wt switch "pr:${pr}" --no-cd --yes 2>&1

    # Resolve the branch name from the PR so we can look up the worktree path.
    branch=$(gh pr view "$pr" --json headRefName --jq '.headRefName')

    worktree_path=$(wt list --format=json | jq -r --arg b "$branch" \
        '.[] | select(.branch == $b) | .path')

    if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
        echo "Error: could not find worktree path for PR #${pr} (branch '$branch')" >&2
        echo "Check 'wt list' to see available worktrees." >&2
        exit 1
    fi
elif [[ -n "$branch" ]]; then
    if ! git rev-parse --git-dir &>/dev/null; then
        echo "Error: not inside a git repository" >&2
        exit 1
    fi

    # Fetch latest so new branches start from up-to-date origin/main.
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
    default_branch="${default_branch:-main}"
    base_flag=()
    echo "◎ Fetching ${default_branch} from origin..." >&2
    if git fetch origin "$default_branch" --quiet 2>&1; then
        base_flag=(--base "origin/${default_branch}")
    else
        echo "⚠ Could not fetch from origin; branching from local ${default_branch}" >&2
    fi

    # Try to create a new branch + worktree.
    create_output=$(wt switch --create "$branch" "${base_flag[@]}" --no-cd --yes 2>&1) || {
        # If the branch already exists, fall through to reuse it.
        # For unexpected errors, surface the output so it's not silently lost.
        if ! echo "$create_output" | grep -qi "already exists"; then
            echo "$create_output" >&2
        fi

        # Check if the branch already has a worktree.
        worktree_path=$(wt list --format=json | jq -r --arg b "$branch" \
            '.[] | select(.branch == $b) | .path')

        if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
            # Branch exists but has no worktree — create one.
            echo "◎ Creating worktree for existing branch '$branch'..." >&2
            wt switch "$branch" --no-cd --yes 2>&1
        else
            echo "◎ Using existing worktree for '$branch'" >&2
        fi
    }

    # Look up the worktree path (needed for both new and existing branches).
    if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
        worktree_path=$(wt list --format=json | jq -r --arg b "$branch" \
            '.[] | select(.branch == $b) | .path')
    fi

    if [[ -z "$worktree_path" || "$worktree_path" == "null" ]]; then
        echo "Error: could not find worktree path for branch '$branch'" >&2
        echo "Check 'wt list' to see available worktrees." >&2
        exit 1
    fi
else
    worktree_path="$dir"
    if [[ ! -d "$worktree_path" ]]; then
        echo "Error: directory does not exist: $worktree_path" >&2
        exit 1
    fi
fi


# --- Build layout ---

base_layout="$HOME/.config/zellij/layouts/claude-tab.kdl"
layout_file=""

if [[ "$resume" == true ]]; then
    # Resume the most recent Claude conversation in this worktree.
    layout_file="${TMPDIR:-/tmp}/zj-worktree-$(date +%s)-$$.kdl"
    status_bar_pane=$(awk '/^layout \{/{next} /pane command=/{exit} {print}' "$base_layout")

    cat > "$layout_file" <<LAYOUT
layout {
$status_bar_pane
    pane command="zsh" size="80%" {
        args "-lic" "claude --resume"
    }
    pane command="lazygit" size="20%"
}
LAYOUT
elif [[ -n "$prompt" ]]; then
    # Generate a layout with the prompt baked into claude's args.
    # This avoids timing issues with zellij action write-chars.
    # The status bar pane is extracted from the base layout so that changes
    # to claude-tab.kdl (e.g. zjstatus config) are automatically picked up.
    layout_file="${TMPDIR:-/tmp}/zj-worktree-$(date +%s)-$$.kdl"

    # Extract the status bar pane block (everything before the first command pane).
    status_bar_pane=$(awk '/^layout \{/{next} /pane command=/{exit} {print}' "$base_layout")

    # Escape the prompt for embedding inside single quotes within a KDL string.
    # Single quotes are escaped as '\'' (end quote, escaped quote, start quote).
    # Double quotes and backslashes are escaped for the outer KDL string layer.
    sq_escaped="${prompt//\'/\'\\\'\'}"
    escaped="${sq_escaped//\\/\\\\}"
    escaped="${escaped//\"/\\\"}"

    cat > "$layout_file" <<LAYOUT
layout {
$status_bar_pane
    pane command="zsh" size="80%" {
        args "-lic" "claude --allowedTools='Edit,Write' '$escaped'"
    }
    pane command="lazygit" size="20%"
}
LAYOUT
else
    layout_file="$base_layout"
fi

# --- Open the tab ---

zellij action new-tab --name "$tab_name" --cwd "$worktree_path" --layout "$layout_file"

echo "Opened tab '$tab_name' in $worktree_path"
